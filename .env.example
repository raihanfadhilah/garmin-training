# Copy to `.env` and fill in. Only email/password are required for the first login.
GARMIN_EMAIL=you@example.com
GARMIN_PASSWORD=your-password

# Optional overrides (defaults shown).
# GARMIN_TOKENSTORE=~/.garmin/tokens
# GARMIN_DB_PATH=~/.garmin/garmin.db
# GARMIN_TRAINING_LOOKBACK_DAYS=30
# GARMIN_REQUEST_DELAY=0.3
